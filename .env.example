## Global project environment variables (root)
## Copy to `.env` and fill real values.

# Backend (Flask)
FLASK_ENV=development
FLASK_DEBUG=1
BACKEND_PORT=5000
BACKEND_EXPOSED_PORT=5000

# Frontend (Next.js)
FRONTEND_EXPOSED_PORT=3000

# External MS SQL Server (hosted outside docker-compose)
DB_HOST=your-host
DB_PORT=1433
DB_NAME=your-db
DB_USER=your-user
DB_PASSWORD=your-password
DB_DRIVER="ODBC Driver 18 for SQL Server"

# This is the base URL your browser uses to call the backend API.
NEXT_PUBLIC_API_BASE_URL=http://localhost:5000

